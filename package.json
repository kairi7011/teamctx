{
  "name": "teamctx",
  "version": "0.1.0",
  "description": "Git-backed team context layer for AI coding tools.",
  "type": "module",
  "bin": {
    "teamctx": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "ci": "npm run format:check && npm run lint && npm run check && npm run build"
  },
  "keywords": [
    "mcp",
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "context"
  ],
  "author": "kairi7011",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
